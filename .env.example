# DevFlow Auto-Dev Environment Configuration
# Copy this file to .env and fill in your API keys
# cp .env.example .env

# =============================================================================
# REQUIRED API KEYS
# =============================================================================

# Anthropic API Key - Required for Claude Code worker agent
# Get your key at: https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# OpenAI API Key - Required for Codex worker agent
# Get your key at: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# =============================================================================
# OPTIONAL API KEYS
# =============================================================================

# Google/Gemini API Key - Optional, enables Gemini worker support
# Get your key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# Perplexity API Key - Optional, enables TaskMaster research features
# Get your key at: https://www.perplexity.ai/settings/api
PERPLEXITY_API_KEY=

# Google API Key - Optional, for TaskMaster Gemini integration
# Note: Different from GEMINI_API_KEY in some contexts
GOOGLE_API_KEY=

# xAI API Key - Optional, enables Grok support via TaskMaster
# Get your key at: https://console.x.ai/
XAI_API_KEY=

# OpenRouter API Key - Optional, enables multi-model access via OpenRouter
# Get your key at: https://openrouter.ai/keys
OPENROUTER_API_KEY=

# =============================================================================
# TASK MASTER CONFIGURATION
# =============================================================================

# TaskMaster Tools Level - Controls which TaskMaster tools are available
# Options: all, standard, core, custom
# - all: Full toolset (~21K tokens)
# - standard: Extended functionality (~10K tokens)
# - core: Essential operations (~5K tokens)
# - custom: User-defined subset
TASK_MASTER_TOOLS=standard

# =============================================================================
# OPENCLAW CONFIGURATION
# =============================================================================

# OpenClaw Gateway Port - Default is 4444
OPENCLAW_PORT=4444

# OpenClaw Log Level - Options: debug, info, warn, error
OPENCLAW_LOG_LEVEL=info

# =============================================================================
# TMUX SESSION CONFIGURATION
# =============================================================================

# Tmux session name for DevFlow
DEVFLOW_SESSION_NAME=devflow

# Auto-restart on crash (true/false)
DEVFLOW_AUTO_RESTART=true

# =============================================================================
# STATE MANAGEMENT
# =============================================================================

# State directory for crash recovery (relative to ~/.openclaw/)
# Default: state
OPENCLAW_STATE_DIR=state

# Checkpoint interval in seconds (for long-running tasks)
CHECKPOINT_INTERVAL=60
